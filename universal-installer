#!/bin/bash

# 1. START SCREEN (Now explicitly says v2.2)
zenity --info --title="Universal Installer v2.2" \
--text="Welcome to v2.2!\n\nPlease select one of the three options.\n\nMade by Learn to Code with Mack." \
--ok-label="Let's Go!"

# 2. MAIN MENU
# OK = Install | Extra = Uninstall | Cancel = App Drawer
zenity --question --title="Main Menu" \
--text="What would you like to do today?" \
--ok-label="Install" \
--extra-button="Uninstall" \
--cancel-label="App Drawer"

RESPONSE=$?

# 3. LOGIC FOR BUTTONS
if [ $RESPONSE -eq 0 ]; then
    # --- INSTALL FLOW ---
    PROGRAM=$(zenity --entry --title="Install" --text="Enter the name of the program to install:")
    [ -z "$PROGRAM" ] && exit 0

    if command -v "$PROGRAM" &> /dev/null; then
        zenity --error --title="Error" --text="You already have this program!" --button="Quit"
        exit 1
    fi

    sudo apt install "$PROGRAM" -y | zenity --progress --title="Installing" --text="Installing $PROGRAM..." --pulsate --auto-close
    
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        zenity --error --title="Error" --text="Could not find '$PROGRAM' or an unexpected error occurred." --button="Quit"
        exit 1
    fi

elif [ $RESPONSE -eq 1 ] || [ "$RESPONSE" == "Uninstall" ]; then
    # --- UNINSTALL FLOW ---
    PROGRAM=$(zenity --entry --title="Uninstall" --text="Enter the name of the program to remove:")
    [ -z "$PROGRAM" ] && exit 0
    
    sudo apt remove "$PROGRAM" -y | zenity --progress --title="Uninstalling" --text="Removing $PROGRAM..." --pulsate --auto-close

else
    # --- APP DRAWER FLOW ---
    APP_NAME=$(zenity --entry --title="App Name" --text="Name of the App:")
    APP_EXEC=$(zenity --entry --title="Command" --text="Command to run it:")
    [ -z "$APP_NAME" ] && exit 0
    
    echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=$APP_EXEC\nType=Application\nTerminal=false" > ~/.local/share/applications/"$APP_NAME".desktop
    zenity --info --text="$APP_NAME added to App Drawer!"
fi

# 4. THE SIGNATURE END SCREEN (Working for all successful paths)
zenity --info --title="Complete" \
--text="Thank you for using this software!\n\nOpen source tool made by Learn to Code with Mack." \
--button="Finish"

exit 0
